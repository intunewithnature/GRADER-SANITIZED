{
  "name": "blind_model_eval",
  "scope": "artifact",
  "fields": {
    "person_name": {"op": "ignore"},
    "model_name": {"op": "pseudonymize", "format": "Model_{n}"},
    "business_name": {"op": "pseudonymize", "format": "Model_{n}"},
    "email": {"op": "redact"},
    "phone": {"op": "redact"},
    "url": {"op": "pseudonymize", "format": "Url_{n}"},
    "api_key": {"op": "redact"},
    "secret_token": {"op": "redact"},
    "exact_price": {"op": "generalize", "style": "business_magnitude"},
    "budget": {"op": "generalize", "style": "business_magnitude"},
    "file_path": {"op": "pseudonymize", "format": "Path_{n}"},
    "account_id": {"op": "pseudonymize", "format": "Account_{n}"},
    "location": {"op": "generalize", "style": "region_or_generic"},
    "date": {"op": "generalize", "style": "relative_time"},
    "client_status": {"op": "ignore"},
    "business_relationship": {"op": "ignore"},
    "private_note": {"op": "ignore"}
  }
}
